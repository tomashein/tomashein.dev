---
import { META, type Locale } from '@config';
import { useTranslation } from '@helpers/i18n';
import Navigation from './Navigation.astro';
import ScrollTop from './ScrollTop.astro';
import Social from './Social.astro';
import LocaleSelector from './LocaleSelector.astro';
import ThemeSelector from './ThemeSelector.astro';

const t = useTranslation(Astro.currentLocale as Locale);
---

<header>
  <div>
    <h1><a href="/">{META.author}</a></h1>
    <h2>{t.meta.role}</h2>
    <p>{t.meta.hero}</p>
    <Navigation />
    <ScrollTop />
  </div>
  <div>
    <Social />
    <LocaleSelector />
    <ThemeSelector />
  </div>
</header>

<style>
  div:last-child {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 32px 16px;
    margin-top: 32px;
  }
  h1 {
    font-size: 36px;
    font-weight: 700;
    line-height: 40px;
    a {
      display: inline-block;
    }
  }
  h2 {
    color: var(--color-primary);
    font-size: 18px;
    font-weight: 600;
    line-height: 28px;
    margin-top: 12px;
  }
  p {
    color: var(--color-secondary);
    line-height: 24px;
    margin-top: 16px;
    max-width: 320px;
  }
  @media (min-width: 640px) {
    h1 {
      font-size: 48px;
      font-weight: 600;
      line-height: 1;
    }
    h2 {
      font-size: 20px;
      font-weight: 500;
      line-height: 28px;
    }
  }
  @media (min-width: 1024px) {
    header {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 96px 0;
      position: sticky;
      width: 48%;
      max-height: 100vh;
      top: 0;
    }
    div:last-child {
      align-items: start;
      gap: 0;
      padding-right: 76px;
    }
  }
</style>
